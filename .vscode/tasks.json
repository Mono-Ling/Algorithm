{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build (MSVC)",
            "command": "${workspaceFolder}\\build.bat",
            "args": [
                "${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compile all .cpp files with MSVC"
        },
        {
            "type": "shell",
            "label": "Build Single File (MSVC)",
            "command": "${workspaceFolder}\\build_single.bat",
            "args": [
                "${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": "build",
            "detail": "Compile current file only with MSVC"
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "del /Q ${workspaceFolder}\\*.exe ${workspaceFolder}\\*.obj ${workspaceFolder}\\*.ilk ${workspaceFolder}\\*.pdb 2>NUL"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "detail": "Remove build artifacts"
        }
    ]
}
